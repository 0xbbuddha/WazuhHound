# Wazuh API credentials
WAZUH_URL=https://wazuh.local:55000
WAZUH_USERNAME=wazuh
WAZUH_PASSWORD=wazuh

# BloodHound CE credentials (for helper-scripts)
BLOODHOUND_URL=http://localhost:8080
BLOODHOUND_USERNAME=admin
BLOODHOUND_SECRET=your-bloodhound-secret

# WazuhHound options
WAZUHHOUND_OUTPUT=./output
WAZUHHOUND_INSECURE=false
WAZUHHOUND_VERBOSE=false
WAZUHHOUND_DEBUG=false
